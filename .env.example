# Polymarket Configuration (for real trading)
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_CHAIN_ID=137  # Polygon mainnet
POLYMARKET_RPC_URL=https://polygon-rpc.com
WALLET_ADDRESS=your_polygon_wallet_address

# Trading Configuration
BASE_STAKE=2.0
MAX_MARTINGALE_LEVEL=5
MIN_SIGNAL_SCORE=70

# Environment
ENVIRONMENT=development  # development or production
LOG_LEVEL=INFO

# NOTE: BTC price & chart data comes from CoinGecko API (FREE, NO API KEY NEEDED!)
# Dashboard opens at: http://localhost:5000
# Railway Deployment
PYTHON_VERSION=3.11
